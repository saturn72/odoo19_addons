<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_public_category_form_inherit_slug" model="ir.ui.view">
        <field name="name">product.public.category.form.inherit.slug</field>
        <field name="model">product.public.category</field>
        <field name="inherit_id" ref="website_sale.product_public_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sequence']" position="after">
                <field name="s72_seo_name" widget="s72_seo_slug" placeholder="Auto-generated from name..."/>
            </xpath>
        </field>
    </record>
</odoo>